    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Categories have required fields', function () {",
                  "    const categories = pm.response.json();",
                  "    pm.expect(categories.length).to.be.above(0);",
                  "    const first = categories[0];",
                  "    pm.expect(first).to.have.property('id');",
                  "    pm.expect(first).to.have.property('name');",
                  "    pm.expect(first).to.have.property('description');",
                  "    pm.expect(first).to.have.property('createdAt');",
                  "    pm.expect(first).to.have.property('updatedAt');",
                  "});",
                  "",
                  "// Save first category ID for subsequent requests",
                  "const categories = pm.response.json();",
                  "if (categories.length > 0) {",
                  "    pm.collectionVariables.set('categoryId', categories[0].id);",
                  "    console.log('Saved categoryId:', categories[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/categories",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            },
            "description": "Returns all categories. Saves the first categoryId for use in product filtering tests."
          },
          "response": []
        },
        {
          "name": "Get Category by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Category has correct structure', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('name');",
                  "    pm.expect(body).to.have.property('description');",
                  "    pm.expect(body).to.have.property('createdAt');",
                  "    pm.expect(body).to.have.property('updatedAt');",
                  "});",
                  "",
                  "pm.test('Returned ID matches requested ID', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(String(body.id)).to.equal(pm.collectionVariables.get('categoryId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register New Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response has correct user fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.email).to.equal('mpala.mbonisi@example.com');",
                  "    pm.expect(body.firstName).to.equal('Test');",
                  "    pm.expect(body.lastName).to.equal('User');",
                  "});",
                  "",
                  "// Auto-save token for subsequent requests",
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('token', pm.response.json().token);",
                  "    console.log('Token saved from registration');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Mbonisi\",\n  \"lastName\": \"Mpala\",\n  \"email\": \"mpala.mbonisi@example.com\",\n  \"password\": \"StrongPassword123\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/auth/register",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registers a new user. Token is automatically saved to {{token}} collection variable."
          },
          "response": []
        },
